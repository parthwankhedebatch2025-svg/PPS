class Complex:
	def initComplex(self):
		self.real,self.image=map(int,input().split())

	def sum(self,c1,c2):
		self.real=c1.real + c2.real
		self.image=c1.image + c2.image
	
	def display(self):
		if self.image >= 0:
			print(f"{self.real} + {self.image}i")
		else:
			print(f"{self.real} - {abs(self.image)}i")
			


# Create three instances
c1 = Complex()
c2 = Complex()
c3 = Complex()

# Initialize two complex numbers
c1.initComplex()
c2.initComplex()

# Compute and display sum
c3.sum(c1, c2)
c3.display()
